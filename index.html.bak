let selected = [];
let activeBrand = 'all';

function repColor(n){
  const stops = ['#ff5d6c','#ff9f5b','#ffc857','#9bd86b','#3ddc84'];
  return stops[Math.max(0,Math.min(4,n-1))];
}
function tcls(t){return {entry:'tier-entry',mid:'tier-mid',high:'tier-high',super:'tier-super'}[t];}
function stars(n){
  let h='';
  const c = repColor(n);
  for(let i=1;i<=5;i++){
    h += `<div class="star" style="background:${i<=n?c:'var(--border)'}"></div>`;
  }
  return h;
}
function repairTextColor(n){ return repColor(n); }

function buildBrandBar(){
  const counts={};
  SCOOTERS.forEach(s=>{counts[s.brand]=(counts[s.brand]||0)+1;});
  let h=`<div class="brand-chip ${activeBrand==='all'?'active':''}" onclick="setBrand('all')">
    <div class="brand-logo-box text">ALL</div>
    <div class="brand-meta"><span class="brand-name">Все бренды</span><span class="brand-count">${SCOOTERS.length} моделей</span></div>
  </div>`;
  Object.keys(BRANDS).forEach(k=>{
    const b=BRANDS[k];
    const cnt=counts[k]||0;
    const logoBox = b.logo
      ? `<div class="brand-logo-box"><img src="${b.logo}" alt="${b.name}" onerror="this.parentElement.outerHTML='<div class=&quot;brand-logo-box text&quot;>${b.name.slice(0,2).toUpperCase()}</div>'"></div>`
      : `<div class="brand-logo-box text">${b.name.slice(0,2).toUpperCase()}</div>`;
    h+=`<div class="brand-chip ${activeBrand===k?'active':''}" onclick="setBrand('${k}')">
      ${logoBox}
      <div class="brand-meta"><span class="brand-name">${b.name}</span><span class="brand-count">${cnt} модел${cnt===1?'ь':cnt<5&&cnt!==0?'и':'ей'}</span></div>
    </div>`;
  });
  document.getElementById('brandChips').innerHTML=h;
}
function setBrand(b){activeBrand=b;buildBrandBar();applyFilters();}

function toggleAdv(id,btn){
  const popup=document.getElementById(id);
  const wasOpen=popup.classList.contains('open');
  document.querySelectorAll('.adv-popup').forEach(p=>p.classList.remove('open'));
  document.querySelectorAll('.adv-toggle').forEach(t=>t.classList.remove('open'));
  if(!wasOpen){popup.classList.add('open');btn.classList.add('open');}
}
document.addEventListener('click',e=>{
  if(!e.target.closest('.filter-group') && !e.target.closest('.vfilter-group')){
    document.querySelectorAll('.adv-popup').forEach(p=>p.classList.remove('open'));
    document.querySelectorAll('.adv-toggle').forEach(t=>t.classList.remove('open'));
  }
});

function getFiltered(){
  const v=id=>{const x=document.getElementById(id).value;return x===''?null:+x;};
  const pMin=v('fPowerMin')??0, pMax=v('fPowerMax')??Infinity;
  const sMin=v('fSpeedMin')??0, sMax=v('fSpeedMax')??Infinity;
  const wMin=v('fWeightMin')??0, wMax=v('fWeightMax')??Infinity;
  const rMin=v('fRangeMin')??0, rMax=v('fRangeMax')??Infinity;
  const vMin=v('fVoltMin')??0, vMax=v('fVoltMax')??Infinity;
  const cMin=v('fCapMin')??0, cMax=v('fCapMax')??Infinity;
  const repMin=v('fRepairMin')??0;
  const query=(document.getElementById('searchInput')?.value||'').trim().toLowerCase();
  return SCOOTERS.filter(s=>{
    if(activeBrand!=='all'&&s.brand!==activeBrand) return false;
    if(s.powerVal<pMin||s.powerVal>pMax) return false;
    if(s.speedVal<sMin||s.speedVal>sMax) return false;
    if(s.weightVal<wMin||s.weightVal>wMax) return false;
    if(s.rangeVal<rMin||s.rangeVal>rMax) return false;
    if(s.voltVal<vMin||s.voltVal>vMax) return false;
    if(s.capVal<cMin||s.capVal>cMax) return false;
    if(s.repair<repMin) return false;
    if(query&&!s.name.toLowerCase().includes(query)&&!s.series.toLowerCase().includes(query)) return false;
    return true;
  });
}

function applyFilters(){
  const filtered=getFiltered();
  document.getElementById('filterResults').textContent=`Найдено: ${filtered.length} из ${SCOOTERS.length}`;
  renderCatalog(filtered);
}

function resetFilters(){
  ['fPowerMin','fPowerMax','fSpeedMin','fSpeedMax','fWeightMin','fWeightMax','fRangeMin','fRangeMax',
   'fVoltMin','fVoltMax','fCapMin','fCapMax','fRepairMin'].forEach(id=>document.getElementById(id).value='');
  activeBrand='all';
  buildBrandBar();
  applyFilters();
}

function renderCatalog(list){
  const c=document.getElementById('catalog');
  if(!list||!list.length){c.innerHTML='<div class="no-results">😕 Нет самокатов по заданным параметрам. Попробуй ослабить фильтры.</div>';return;}
  const bLogo=(brand)=>{
    const b=BRANDS[brand];
    if(!b) return '';
    if(!b.logo) return `<div class="photo-brand"><span>${b.name}</span></div>`;
    return `<div class="photo-brand"><img src="${b.logo}" alt="${b.name}" onerror="this.parentElement.innerHTML='<span>${b.name}</span>'"></div>`;
  };
  c.innerHTML=list.map(s=>{
    const sel=selected.includes(s.id);
    const rc=repairTextColor(s.repair);
    return `<div class="card ${sel?'selected':''}">
      <div class="card-photo" onclick="this.closest('.card').classList.toggle('zoomed')" style="cursor: pointer;">
        <img src="${s.photo}" alt="${s.name}" onerror="this.src='https://placehold.co/300x150/1b202e/5b8cff?text=${encodeURIComponent(s.name)}'">
        ${bLogo(s.brand)}
        <span class="photo-tier ${tcls(s.tier)}">${s.tierLabel}</span>
      </div>
      <div class="card-hd">
        <div class="card-series">${s.series}</div>
        <div class="card-name">${s.name}</div>
      </div>
      <div class="key-specs">
        <div class="ks"><div class="ks-lbl">Мощность</div><div class="ks-val">${s.power}<span class="ks-u"> ном</span></div></div>
        <div class="ks"><div class="ks-lbl">Скорость</div><div class="ks-val">${s.speed}<span class="ks-u"> км/ч</span></div></div>
        <div class="ks"><div class="ks-lbl">Пробег</div><div class="ks-val">${s.range}<span class="ks-u"> км</span></div></div>
        <div class="ks"><div class="ks-lbl">Вес</div><div class="ks-val">${s.weight}<span class="ks-u"> кг</span></div></div>
      </div>
      <div class="extra">
        <div class="er"><span class="er-l">Колёса</span><span class="er-v">${s.wheels}</span></div>
        <div class="er"><span class="er-l">Батарея</span><span class="er-v">${s.battery}</span></div>
        <div class="er"><span class="er-l">Напряжение</span><span class="er-v">${s.batteryV}</span></div>
        <div class="er"><span class="er-l">Элементы</span><span class="er-v">${s.cells}</span></div>
        <div class="er"><span class="er-l">Подвеска</span><span class="er-v" style="font-size:10px">${s.suspension}</span></div>
        <div class="er"><span class="er-l">Защита</span><span class="er-v">${s.waterproof}</span></div>
        <div class="er"><span class="er-l">Нагрузка</span><span class="er-v">${s.load}</span></div>
        <div class="er"><span class="er-l">Зарядка</span><span class="er-v">${s.charge}</span></div>
      </div>
      <div class="repair">
        <span class="repair-lbl">Ремонтопригодность</span>
        <div class="stars">${stars(s.repair)}<span class="repair-txt" style="color:${rc}">${s.repairTxt}</span></div>
      </div>
      <div class="price-row">
        <span class="price-lbl">Цена</span>
        <span class="price-val">${s.price}</span>
      </div>
      <div class="cons">
        <div class="cons-hd">Минусы из отзывов</div>
        <ul class="cons-list">${s.cons.map(c=>`<li>${c}</li>`).join('')}</ul>
      </div>
      <button class="add-btn ${sel?'added':''}" onclick="toggle('${s.id}')">
        ${sel?'✓ В сравнении':'+ Добавить в сравнение'}
      </button>
    </div>`;
  }).join('');
}

function toggle(id){
  if(selected.includes(id)) selected=selected.filter(x=>x!==id);
  else if(selected.length<4) selected.push(id);
  applyFilters();
  updateCompareBar();
}

function clearAll(){
  selected=[];
  applyFilters();
  updateCompareBar();
}

function updateCompareBar(){
  const bar=document.getElementById('compareBar');
  document.getElementById('compareCount').textContent=selected.length;
  document.getElementById('btnCompare').disabled=selected.length<2;
  bar.classList.toggle('show',selected.length>0);
}

function openModal(){
  const items=selected.map(id=>SCOOTERS.find(s=>s.id===id));
  const rows=[
    {l:'Бренд',fn:s=>BRANDS[s.brand]?.name||s.brand,t:'text'},
    {l:'Серия',fn:s=>s.series,t:'text'},
    {l:'Цена',fn:s=>s.price,t:'text'},
    {l:'Мощность ном.',fn:s=>s.powerVal,u:'W',hi:true},
    {l:'Мощность пик',fn:s=>parseInt(s.powerPeak)||s.powerVal*2,u:'W',hi:true},
    {l:'Макс. скорость',fn:s=>s.speedVal,u:' км/ч',hi:true},
    {l:'Пробег',fn:s=>s.rangeVal,u:' км',hi:true},
    {l:'Вес',fn:s=>s.weightVal,u:' кг',hi:false},
    {l:'Колёса',fn:s=>s.wheels,t:'text'},
    {l:'Подвеска',fn:s=>s.suspension,t:'text'},
    {l:'Батарея',fn:s=>s.battery,t:'text'},
    {l:'Напряжение АКБ',fn:s=>s.batteryV,t:'text'},
    {l:'Тип элементов',fn:s=>s.cells,t:'text'},
    {l:'Защита',fn:s=>s.waterproof,t:'text'},
    {l:'Нагрузка',fn:s=>s.load,t:'text'},
    {l:'Зарядка',fn:s=>s.charge,t:'text'},
    {l:'Ремонтопригодность',fn:s=>s.repairTxt,t:'text'},
  ];
  let h=`<thead><tr><th>Параметр</th>${items.map(s=>`<th>${s.name}</th>`).join('')}</tr></thead><tbody>`;
  rows.forEach(r=>{
    h+=`<tr><td>${r.l}</td>`;
    if(r.t==='text'){h+=items.map(s=>`<td>${r.fn(s)}</td>`).join('');}
    else{
      const vals=items.map(s=>r.fn(s));
      const best=r.hi?Math.max(...vals):Math.min(...vals);
      const worst=r.hi?Math.min(...vals):Math.max(...vals);
      h+=items.map((s,i)=>{
        const val=vals[i],cls=val===best?'best':(items.length>2&&val===worst?'worst':'');
        return `<td class="${cls}">${val}${r.u||''}</td>`;
      }).join('');
    }
    h+='</tr>';
  });
  h+=`<tr><td>Минусы</td>${items.map(s=>`<td class="cons-cell">${s.cons.map(c=>`· ${c}`).join('<br>')}</td>`).join('')}</tr></tbody>`;
  document.getElementById('cmpTable').innerHTML=h;
  document.getElementById('overlay').classList.add('open');
  document.body.style.overflow='hidden';
}
function closeModal(){document.getElementById('overlay').classList.remove('open');document.body.style.overflow='';}
document.getElementById('overlay').addEventListener('click',e=>{if(e.target===e.currentTarget)closeModal();});

buildBrandBar();
applyFilters();
</script>
</body>
</html>